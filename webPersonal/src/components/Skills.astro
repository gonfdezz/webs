---
import Icon from './Icon.astro';

const categories = [
	{
		title: 'Algoritmia y estructuras de datos',
		icon: 'tree-structure' as const,
		intro:
			'La base de un software eficiente es una lógica sólida. Me especializo en diseñar soluciones óptimas enfocadas en el rendimiento y la escalabilidad.',
		items: [
			{
				label: 'Estructuras de datos avanzadas',
				desc: 'Grafos, árboles, colas de prioridad y tablas hash, incluyendo gestión de colisiones abiertas y cerradas.',
			},
			{
				label: 'Optimización de algoritmos',
				desc: 'Análisis de complejidad temporal y espacial, y refactorización para mejorar la eficiencia del código.',
			},
		],
		wide: false,
	},
	{
		title: 'Desarrollo web full stack',
		icon: 'globe' as const,
		intro:
			'Construyo aplicaciones web modernas, rápidas y adaptables, cuidando tanto la lógica del servidor como la experiencia de usuario.',
		items: [
			{ label: 'Frontend', desc: 'Interfaces dinámicas y optimizadas con React, Astro y Tailwind CSS.' },
			{ label: 'Backend', desc: 'Lógica de servidor y APIs básicas con Node.js.' },
		],
		wide: false,
	},
	{
		title: 'Arquitectura de software y diseño',
		icon: 'blueprint' as const,
		intro:
			'Escribir código que funciona no es suficiente: me enfoco en que sea mantenible y escalable a largo plazo.',
		items: [
			{ label: 'Diseño de interfaces', desc: 'Contratos claros entre componentes y sistemas.' },
			{ label: 'Arquitectura en capas', desc: 'Bajo acoplamiento y alta cohesión entre los módulos del proyecto.' },
		],
		wide: false,
	},
	{
		title: 'Gestión de datos',
		icon: 'database' as const,
		intro: null,
		items: [
			{
				label: 'Bases de datos y SQL',
				desc: 'Modelos de datos relacionales, persistencia y consultas eficientes para la manipulación de información.',
			},
		],
		wide: false,
	},
	{
		title: 'Herramientas y colaboración',
		icon: 'git-branch' as const,
		intro: null,
		items: [
			{
				label: 'Control de versiones',
				desc: 'Gestión del ciclo de vida del código y trabajo colaborativo con Git y GitHub.',
			},
		],
		wide: true,
	},
];

const skillGroups = [
	{
		label: 'Frontend',
		items: ['HTML', 'JavaScript', 'React', 'Astro', 'Tailwind CSS'],
	},
	{
		label: 'Backend & datos',
		items: ['Node.js', 'Java', 'Python', 'SQL'],
	},
	{
		label: 'Herramientas',
		items: ['VS Code', 'Eclipse', 'Git', 'GitHub'],
	},
];
---

<section id="skills" class="border-t border-bone-100/10 px-6 py-20">
	<div class="mx-auto max-w-5xl">
		<h2 data-reveal class="text-2xl font-semibold tracking-tight text-bone-100">Skills</h2>

		<div class="mt-10 grid gap-6 md:grid-cols-2">
			{
				categories.map((cat) => (
					<div
						data-reveal
						class:list={['rounded-xl border border-bone-100/10 p-6 md:p-7', cat.wide && 'md:col-span-2']}
					>
						<div class="flex items-center gap-3">
							<Icon name={cat.icon} class="h-5 w-5 shrink-0 text-gold-400" />
							<h3 class="text-base font-semibold text-bone-100">{cat.title}</h3>
						</div>

						{cat.intro && <p class="mt-3 text-sm leading-relaxed text-bone-500">{cat.intro}</p>}

						<ul
							class:list={[
								'mt-4 space-y-3',
								cat.wide && 'sm:flex sm:flex-wrap sm:gap-x-12 sm:gap-y-3 sm:space-y-0',
							]}
						>
							{cat.items.map((item) => (
								<li class:list={[cat.wide && 'sm:max-w-xs']}>
									<p class="text-sm font-medium text-bone-100">{item.label}</p>
									<p class="mt-1 text-sm leading-relaxed text-bone-500">{item.desc}</p>
								</li>
							))}
						</ul>
					</div>
				))
			}
		</div>

		<div class="mt-14 border-t border-bone-100/10 pt-10">
			<p data-reveal class="font-mono text-xs tracking-[0.15em] text-bone-700 uppercase">Stack</p>
			<div class="mt-6 grid gap-x-10 gap-y-10 sm:grid-cols-3">
				{
					skillGroups.map((group) => (
						<div data-reveal>
							<p class="font-mono text-xs tracking-[0.15em] text-gold-400 uppercase">{group.label}</p>
							<ul class="mt-4 space-y-2.5">
								{group.items.map((item) => (
									<li class="text-sm text-bone-300">{item}</li>
								))}
							</ul>
						</div>
					))
				}
			</div>
		</div>
	</div>
</section>
