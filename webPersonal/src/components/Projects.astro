---
import ProjectCard from './ProjectCard.astro';

const projects = [
	{
		title: 'Proyecto Placeholder 1',
		description: 'Descripción corta de un proyecto de ejemplo pendiente de sustituir.',
		tags: ['Astro', 'Tailwind CSS'],
		demoUrl: '#',
		githubUrl: 'https://github.com/gonfdezz',
	},
	{
		title: 'Proyecto Placeholder 2',
		description: 'Descripción corta de un proyecto de ejemplo pendiente de sustituir.',
		tags: ['Node.js', 'SQL'],
		demoUrl: '#',
		githubUrl: 'https://github.com/gonfdezz',
	},
	{
		title: 'Proyecto Placeholder 3',
		description: 'Descripción corta de un proyecto de ejemplo pendiente de sustituir.',
		tags: ['Java', 'Python'],
		demoUrl: '#',
		githubUrl: 'https://github.com/gonfdezz',
	},
];

const [featured, ...rest] = projects;
---

<section id="proyectos" class="border-t border-bone-100/10 px-6 py-20">
	<div class="mx-auto max-w-5xl">
		<h2 data-reveal class="text-2xl font-semibold tracking-tight text-bone-100">Proyectos</h2>
		<div class="mt-8 flex flex-col gap-6">
			<ProjectCard {...featured} index={1} featured />
			<div class="grid gap-6 md:grid-cols-2">
				{rest.map((project, i) => <ProjectCard {...project} index={i + 2} />)}
			</div>
		</div>
	</div>
</section>
