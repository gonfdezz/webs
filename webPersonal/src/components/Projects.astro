];
---

<section id="proyectos" class="mx-auto max-w-5xl px-6 py-20">
	<h2 class="text-2xl font-semibold text-zinc-100">Proyectos</h2>
	<div class="mt-8 grid gap-8 md:grid-cols-3">
		{projects.map((project) => <ProjectCard {...project} />)}
	</div>
</section>
