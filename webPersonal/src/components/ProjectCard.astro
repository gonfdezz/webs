---
import Icon from './Icon.astro';

interface Props {
	title: string;
	description: string;
	tags: string[];
	demoUrl: string;
	githubUrl: string;
	index: number;
	featured?: boolean;
}

const { title, description, tags, demoUrl, githubUrl, index, featured = false } = Astro.props;
const num = String(index).padStart(2, '0');
---

{
	featured ? (
		<article data-reveal class="rounded-xl border border-bone-100/10 bg-ink-900 p-8 md:p-10">
			<div class="flex items-start justify-between gap-6">
				<span class="font-mono text-xs text-bone-700">{num}</span>
				<div class="flex gap-4 text-sm">
					<a
						href={demoUrl}
						class="inline-flex items-center gap-1.5 text-gold-400 transition hover:text-gold-300"
					>
						Ver demo
						<Icon name="arrow-up-right" class="h-3.5 w-3.5" />
					</a>
					<a
						href={githubUrl}
						class="inline-flex items-center gap-1.5 text-bone-500 transition hover:text-bone-100"
					>
						<Icon name="github-logo" class="h-3.5 w-3.5" />
						Código
					</a>
				</div>
			</div>
			<h3 class="mt-6 text-xl font-semibold text-bone-100 md:text-2xl">{title}</h3>
			<p class="mt-3 max-w-[60ch] leading-relaxed text-bone-500">{description}</p>
			<ul class="mt-6 flex flex-wrap gap-2">
				{tags.map((tag) => (
					<li class="rounded-xl border border-bone-100/15 px-3 py-1 text-xs text-bone-300">{tag}</li>
				))}
			</ul>
		</article>
	) : (
		<article data-reveal class="flex flex-col justify-between border-t border-bone-100/10 pt-6">
			<div>
				<div class="flex items-start justify-between gap-4">
					<h3 class="text-lg font-semibold text-bone-100">{title}</h3>
					<span class="font-mono text-xs text-bone-700">{num}</span>
				</div>
				<p class="mt-3 text-sm leading-relaxed text-bone-500">{description}</p>
				<ul class="mt-4 flex flex-wrap gap-2">
					{tags.map((tag) => (
						<li class="rounded-xl border border-bone-100/15 px-3 py-1 text-xs text-bone-300">{tag}</li>
					))}
				</ul>
			</div>
			<div class="mt-6 flex gap-4 text-sm">
				<a
					href={demoUrl}
					class="inline-flex items-center gap-1.5 text-gold-400 transition hover:text-gold-300"
				>
					Ver demo
					<Icon name="arrow-up-right" class="h-3.5 w-3.5" />
				</a>
				<a
					href={githubUrl}
					class="inline-flex items-center gap-1.5 text-bone-500 transition hover:text-bone-100"
				>
					<Icon name="github-logo" class="h-3.5 w-3.5" />
					Código
				</a>
			</div>
		</article>
	)
}
